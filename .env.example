# SafeMGM Environment Variables
# Copy this file to .env.local and fill in your values

# Google Gemini API (primary AI model)
# Get from: https://aistudio.google.com → Get API key
GOOGLE_GEMINI_API_KEY=

# OpenAI (fallback if Gemini rate-limited)
# Get from: https://platform.openai.com → API Keys
OPENAI_API_KEY=

# NewsAPI.org (FREE alternative to Bright Data - no credit card required)
# Get from: https://newsapi.org/register → Free tier available
# If not set, app will show sample news articles
NEWS_API_KEY=

# Bright Data SERP API (optional - requires credit card)
# Get from: https://brightdata.com/cp/start → Create SERP API zone
# Only needed if you want real Google News search (3 bonus points)
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_SERP_ZONE=
